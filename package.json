{
	"name": "@lesjoursfr/bin-wrapper",
	"version": "13.0.7",
	"description": "Binary wrapper that makes your programs seamlessly available as local dependencies",
	"license": "MIT",
	"repository": {
		"url": "git+https://github.com/lesjoursfr/bin-wrapper.git"
	},
	"homepage": "https://github.com/lesjoursfr/bin-wrapper#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/bin-wrapper/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"author": {
		"name": "Kevin Mårtensson",
		"email": "kevinmartensson@gmail.com",
		"url": "https://github.com/kevva"
	},
	"engines": {
		"node": "22.x || 24.x"
	},
	"exports": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"files": [
		"lib/**/*",
		"src/**/*"
	],
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"check-lint": "eslint",
		"check-format": "prettier --check .",
		"check-tsc": "tsc --noEmit",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"build": "tsc",
		"test": "NODE_OPTIONS='--loader=ts-node/esm' mocha"
	},
	"keywords": [
		"bin",
		"check",
		"local",
		"wrapper"
	],
	"type": "module",
	"dependencies": {
		"@lesjoursfr/bin-check": "^8.0.5",
		"@lesjoursfr/bin-version": "^8.0.5",
		"arch": "^3.0.0",
		"axios": "^1.15.0",
		"content-disposition": "^1.1.0",
		"file-type": "^22.0.1",
		"semver": "^7.7.4",
		"semver-truncate": "^3.0.0",
		"tar": "^7.5.13"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@tsconfig/node22": "22.0.5",
		"@types/content-disposition": "0.5.9",
		"@types/mocha": "10.0.10",
		"@types/node": "24.12.2",
		"@types/semver": "7.7.1",
		"eslint": "10.2.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.4.0",
		"isexe": "4.0.0",
		"mocha": "11.7.5",
		"nock": "14.0.12",
		"prettier": "3.8.2",
		"tempy": "3.2.0",
		"ts-node": "10.9.2",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.1"
	},
	"packageManager": "yarn@4.13.0"
}
